# ===== PATH CONFIGURATION =====
# Where your .zst dump files are located
DUMPS_PATH=./data/dumps

# Storage for decompressed JSON files
EXTRACTED_PATH=./data/extracted

# Storage for parsed CSV files
CSV_PATH=./data/csv

# Storage for classifier output files
OUTPUT_PATH=./data/output

# PostgreSQL data location (postgres profiles only)
PGDATA_PATH=./data/database

# ===== DATABASE CONFIGURATION (postgres profiles) =====
DB_NAME=datasets
DB_SCHEMA=reddit
POSTGRES_PORT=5432

# ===== WEBUI CONFIGURATION (webui profile) =====
# LibreChat web UI port
LIBRECHAT_PORT=3080
# Redash web UI port  
REDASH_PORT=5000
# Redash workers
REDASH_WEB_WORKERS=2
# Redash query timeout (seconds)
REDASH_QUERY_TIMEOUT=300

# LibreChat settings (registration enabled by default in docker-compose)

# Secrets (generate new ones with: openssl rand -base64 32)
REDASH_COOKIE_SECRET=
REDASH_SECRET_KEY=
REDASH_API_KEY=

# LibreChat secrets
LIBRECHAT_JWT_SECRET=
LIBRECHAT_CREDS_KEY=
LIBRECHAT_CREDS_IV=