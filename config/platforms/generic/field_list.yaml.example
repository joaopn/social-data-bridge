# Generic platform field list configuration (example)
#
# This file defines which fields to extract from your JSON data.
# Copy this to field_list.yaml and customize for your data.
#
# Structure:
#   data_type_name:
#     - field1
#     - field2
#     - nested.field.path
#
# The data_type names here should match what you put in config/parse/pipeline.yaml
# under processing.data_types
#
# Features:
#   - Dot notation for nested fields: "user.profile.name"
#   - Array indexing: "items.0.id" (first element of items array)
#   - Arrays become pipe-separated strings: [a, b, c] -> "a|b|c"

# Example: Social media posts
posts:
  - id
  - created_at
  - author
  - content
  - likes
  - shares
  - is_public

# Example: User data
users:
  - id
  - username
  - email
  - created_at
  - profile.bio
  - profile.location
  - followers_count
