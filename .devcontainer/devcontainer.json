{
    "name": "Social Data Pipeline Demo",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "mounts": [
        "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
    ],
    "postCreateCommand": "bash .devcontainer/post-create.sh",
    "forwardPorts": [8050, 8000, 5432],
    "portsAttributes": {
        "8050": {
            "label": "Jobs scheduler UI",
            "onAutoForward": "notify"
        },
        "8000": {
            "label": "PostgreSQL MCP (SSE)",
            "onAutoForward": "silent"
        },
        "5432": {
            "label": "PostgreSQL",
            "onAutoForward": "silent"
        }
    },
    "remoteUser": "vscode"
}
