{
    "name": "Social Data Pipeline Demo",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "mounts": [
        "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
    ],
    "postCreateCommand": "bash .devcontainer/post-create.sh",
    "postAttachCommand": "code --reuse-window tests/demo/WELCOME.md",
    "forwardPorts": [8050, 8000, 3000, 9000, 5432],
    "portsAttributes": {
        "8050": {
            "label": "Jobs scheduler UI",
            "onAutoForward": "openBrowser"
        },
        "8000": {
            "label": "PostgreSQL MCP (SSE)",
            "onAutoForward": "silent"
        },
        "3000": {
            "label": "MongoDB MCP (HTTP)",
            "onAutoForward": "silent"
        },
        "9000": {
            "label": "StarRocks MCP (HTTP)",
            "onAutoForward": "silent"
        },
        "5432": {
            "label": "PostgreSQL",
            "onAutoForward": "silent"
        }
    },
    "remoteUser": "vscode",
    "customizations": {
        "vscode": {
            "settings": {
                "workbench.startupEditor": "none",
                "workbench.colorTheme": "Monokai Dimmed",
                "workbench.editorAssociations": {
                    "*.md": "vscode.markdown.preview.editor"
                }
            }
        }
    }
}
